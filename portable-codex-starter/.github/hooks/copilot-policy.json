{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/hook-log.mjs session-start",
        "powershell": "node .github/hooks/scripts/hook-log.mjs session-start",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/hook-log.mjs user-prompt",
        "powershell": "node .github/hooks/scripts/hook-log.mjs user-prompt",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/pre-tool-policy.mjs",
        "powershell": "node .github/hooks/scripts/pre-tool-policy.mjs",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/hook-log.mjs post-tool-use",
        "powershell": "node .github/hooks/scripts/hook-log.mjs post-tool-use",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/hook-log.mjs error",
        "powershell": "node .github/hooks/scripts/hook-log.mjs error",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/hook-log.mjs agent-stop",
        "powershell": "node .github/hooks/scripts/hook-log.mjs agent-stop",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/hook-log.mjs subagent-stop",
        "powershell": "node .github/hooks/scripts/hook-log.mjs subagent-stop",
        "cwd": ".",
        "timeoutSec": 5
      }
    ]
  }
}
